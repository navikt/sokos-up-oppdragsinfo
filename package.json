{
	"name": "sokos-up-oppdragsinfo",
	"version": "1.0.0",
	"description": "Oppdragsinfo i Utbetalingsportalen",
	"type": "module",
	"scripts": {
		"dev": "vite --mode mock",
		"dev:backend": "vite --mode backend",
		"build": "tsc && vite build",
		"playwright": "playwright test",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"knip": "knip",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@grafana/faro-web-sdk": "2.5.0",
		"@hookform/resolvers": "5.2.2",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-css": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"axios": "1.16.0",
		"dayjs": "1.11.20",
		"react": "19.2.5",
		"react-dom": "19.2.5",
		"react-hook-form": "7.75.0",
		"react-router": "7.14.2",
		"swr": "2.4.1",
		"zod": "4.4.3",
		"zustand": "5.0.13"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.3",
		"@biomejs/biome": "2.4.14",
		"@navikt/aksel-stylelint": "7.40.0",
		"@playwright/test": "1.59.1",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"husky": "9.1.7",
		"knip": "6.11.0",
		"lint-staged": "16.4.0",
		"msw": "2.14.3",
		"stylelint": "17.11.0",
		"stylelint-config-standard": "40.0.0",
		"typescript": "6.0.3",
		"vite": "8.0.10",
		"vite-plugin-css-injected-by-js": "5.0.1"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	},
	"stylelint": {
		"extends": [
			"stylelint-config-standard",
			"@navikt/aksel-stylelint/recommended"
		],
		"rules": {
			"aksel/design-token-no-global-override": [
				true,
				{
					"severity": "warning"
				}
			],
			"selector-class-pattern": null
		},
		"ignoreFiles": [
			"dist/**/*",
			"playwright-report/**/*"
		]
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.1.2",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
